{
  "info": {
    "name": "PawsHaven API Collection",
    "description": "API collection for PawsHaven platform management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://trivia-pub-about-investigation.trycloudflare.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "User Registration",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"},
            "url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"},
            "url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "User Logout",
          "request": { "method": "POST", "url": {"raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api", "auth", "logout"]} }
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Get Profile Info",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/users/me", "host": ["{{base_url}}"], "path": ["api", "users", "me"]} }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"John Updated\"\n}"},
            "url": {"raw": "{{base_url}}/api/users/me", "host": ["{{base_url}}"], "path": ["api", "users", "me"]}
          }
        },
        {
          "name": "Get User Details",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/users/:user_id", "host": ["{{base_url}}"], "path": ["api", "users", ":user_id"], "variable": [{"key": "user_id", "value": "dXNlcl8y"}]} }
        },
        {
          "name": "Remove User Account",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"otp\": \"123456\"\n}"},
            "url": {"raw": "{{base_url}}/api/users/:user_id", "host": ["{{base_url}}"], "path": ["api", "users", ":user_id"], "variable": [{"key": "user_id", "value": "dXNlcl8y"}]}
          }
        }
      ]
    },
    {
      "name": "Pet Catalog",
      "item": [
        {
          "name": "List Animals",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/animals", "host": ["{{base_url}}"], "path": ["api", "animals"]} }
        },
        {
          "name": "Search Catalog",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/animals/search?q=Buddy", "host": ["{{base_url}}"], "path": ["api", "animals", "search"], "query": [{"key": "q", "value": "Buddy"}]} }
        },
        {
          "name": "Get Animal Details",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/animals/:animal_id", "host": ["{{base_url}}"], "path": ["api", "animals", ":animal_id"], "variable": [{"key": "animal_id", "value": "YW5pbWFsXzE="}]} }
        },
        {
          "name": "Get Medical Records",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/animals/:animal_id/medical", "host": ["{{base_url}}"], "path": ["api", "animals", ":animal_id", "medical"], "variable": [{"key": "animal_id", "value": "YW5pbWFsXzE="}]} }
        },
        {
          "name": "Import Records",
          "request": { "method": "POST", "url": {"raw": "{{base_url}}/api/animals/import", "host": ["{{base_url}}"], "path": ["api", "animals", "import"]} }
        }
      ]
    },
    {
      "name": "Adoptions & Certificates",
      "item": [
        {
          "name": "Submit Adoption Application",
          "request": { "method": "POST", "url": {"raw": "{{base_url}}/api/animals/:animal_id/adopt", "host": ["{{base_url}}"], "path": ["api", "animals", ":animal_id", "adopt"], "variable": [{"key": "animal_id", "value": "YW5pbWFsXzE="}]} }
        },
        {
          "name": "List Applications",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/adoptions", "host": ["{{base_url}}"], "path": ["api", "adoptions"]} }
        },
        {
          "name": "Download Adoption Certificate",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/adoptions/:adoption_id/certificate", "host": ["{{base_url}}"], "path": ["api", "adoptions", ":adoption_id", "certificate"], "variable": [{"key": "adoption_id", "value": "YWRvcHRpb25fMQ=="}]} }
        }
      ]
    },
    {
      "name": "Veterinary Services",
      "item": [
        {
          "name": "Get All Appointments",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/appointments", "host": ["{{base_url}}"], "path": ["api", "appointments"]} }
        },
        {
          "name": "Schedule Appointment",
          "request": { "method": "POST", "url": {"raw": "{{base_url}}/api/appointments", "host": ["{{base_url}}"], "path": ["api", "appointments"]} }
        },
        {
          "name": "Cancel Appointment",
          "request": { "method": "DELETE", "url": {"raw": "{{base_url}}/api/appointments/:apt_id", "host": ["{{base_url}}"], "path": ["api", "appointments", ":apt_id"], "variable": [{"key": "apt_id", "value": "5"}]} }
        },
        {
          "name": "Diagnostic Tool",
          "request": { "method": "POST", "url": {"raw": "{{base_url}}/api/vet/diagnose", "host": ["{{base_url}}"], "path": ["api", "vet", "diagnose"]} }
        }
      ]
    },
    {
      "name": "Store & Donations",
      "item": [
        {
          "name": "Submit Donation",
          "request": { "method": "POST", "body": {"mode": "raw", "raw": "{\"amount\": 50}"}, "url": {"raw": "{{base_url}}/api/donations", "host": ["{{base_url}}"], "path": ["api", "donations"]} }
        },
        {
          "name": "Download Receipt",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/donations/receipt/:filename", "host": ["{{base_url}}"], "path": ["api", "donations", "receipt", ":filename"], "variable": [{"key": "filename", "value": "receipt_001.pdf"}]} }
        },
        {
          "name": "Verify Coupon",
          "request": { "method": "POST", "url": {"raw": "{{base_url}}/api/store/coupon", "host": ["{{base_url}}"], "path": ["api", "store", "coupon"]} }
        },
        {
          "name": "Process Checkout",
          "request": { "method": "POST", "body": {"mode": "raw", "raw": "{\"amount\": 10, \"coupon_code\": \"FREE\"}"}, "url": {"raw": "{{base_url}}/api/store/checkout", "host": ["{{base_url}}"], "path": ["api", "store", "checkout"]} }
        }
      ]
    },
    {
      "name": "Utility Endpoints",
      "item": [
        {
          "name": "Download File",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/files/download?path=documents/report.pdf", "host": ["{{base_url}}"], "path": ["api", "files", "download"], "query": [{"key": "path", "value": "documents/report.pdf"}]} }
        },
        {
          "name": "Record Sync",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/files/remote?url=https://pawshaven.org/sync", "host": ["{{base_url}}"], "path": ["api", "files", "remote"], "query": [{"key": "url", "value": "https://pawshaven.org/sync"}]} }
        },
        {
          "name": "Upload Media",
          "request": { "method": "POST", "url": {"raw": "{{base_url}}/api/upload/avatar", "host": ["{{base_url}}"], "path": ["api", "upload", "avatar"]} }
        },
        {
          "name": "Export Archives",
          "request": { "method": "POST", "body": {"mode": "raw", "raw": "{\"format\": \"json\", \"data\": \"user_archive\"}"}, "url": {"raw": "{{base_url}}/api/export", "host": ["{{base_url}}"], "path": ["api", "export"]} }
        },
        {
          "name": "System Health",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api", "health"]} }
        },
        {
          "name": "Domain Redirect",
          "request": { "method": "GET", "url": {"raw": "{{base_url}}/api/redirect?url=https://twitter.com/pawshaven", "host": ["{{base_url}}"], "path": ["api", "redirect"], "query": [{"key": "url", "value": "https://twitter.com/pawshaven"}]} }
        }
      ]
    }
  ]
}